generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  AUTHOR
  ADMIN
}

enum ModStatus {
  DRAFT
  PUBLISHED
}

enum MediaType {
  SCREENSHOT
  VIDEO
}

model User {
  id           String    @id @default(cuid())
  supabaseId   String?   @unique
  email        String    @unique
  username     String    @unique
  passwordHash String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile   Profile?
  mods      Mod[]
  ratings   Rating[]
  comments  Comment[]
  downloads DownloadEvent[]
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  avatarUrl String?
  bannerUrl String?
  bio       String?
  website   String?
  twitter   String?
  github    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  steamAppId  Int?
  coverUrl    String?
  createdAt   DateTime @default(now())

  mods         Mod[]
  categories   Category[]
  indexedMods  IndexedMod[]
  syncSources  SyncSource[]
}

model Category {
  id     String @id @default(cuid())
  name   String
  slug   String
  gameId String?

  game Game? @relation(fields: [gameId], references: [id], onDelete: SetNull)
  mods Mod[]

  @@unique([slug, gameId])
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  mods ModTag[]
}

model Mod {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String
  status        ModStatus @default(DRAFT)
  gameId        String
  authorId      String
  categoryId    String?
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  game         Game            @relation(fields: [gameId], references: [id])
  author       User            @relation(fields: [authorId], references: [id])
  category     Category?       @relation(fields: [categoryId], references: [id])
  versions     ModVersion[]
  media        ModMedia[]
  tags         ModTag[]
  dependencies ModDependency[] @relation("ModDependencies")
  dependents   ModDependency[] @relation("ModDependents")
  ratings      Rating[]
  comments     Comment[]
  downloads    DownloadEvent[]

  @@index([gameId])
  @@index([authorId])
  @@index([status])
  @@index([updatedAt])
}

model ModVersion {
  id        String   @id @default(cuid())
  modId     String
  version   String
  changelog String?
  createdAt DateTime @default(now())

  mod   Mod       @relation(fields: [modId], references: [id], onDelete: Cascade)
  files ModFile[]

  @@unique([modId, version])
}

model ModFile {
  id         String @id @default(cuid())
  versionId  String
  storageKey String
  filename   String
  sizeBytes  Int
  mimeType   String

  version ModVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
}

model ModMedia {
  id         String    @id @default(cuid())
  modId      String
  type       MediaType @default(SCREENSHOT)
  storageKey String?
  url        String?
  sortOrder  Int       @default(0)

  mod Mod @relation(fields: [modId], references: [id], onDelete: Cascade)
}

model ModTag {
  modId String
  tagId String

  mod Mod @relation(fields: [modId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([modId, tagId])
}

model ModDependency {
  modId          String
  dependsOnModId String

  mod          Mod @relation("ModDependencies", fields: [modId], references: [id], onDelete: Cascade)
  dependsOnMod Mod @relation("ModDependents", fields: [dependsOnModId], references: [id], onDelete: Cascade)

  @@id([modId, dependsOnModId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  modId     String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mod  Mod  @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@unique([userId, modId])
  @@index([modId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  modId     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mod  Mod  @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@index([modId])
}

model DownloadEvent {
  id        String   @id @default(cuid())
  modId     String
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  mod  Mod   @relation(fields: [modId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([modId])
}

// ─── External mod index (synced from GameBanana, Workshop, etc.) ─────────────

enum SyncSourceType {
  GAMEBANANA
  STEAM_WORKSHOP
  TF2MAPS
  CUSTOM
}

enum SyncJobType {
  METADATA_SYNC
  IMAGE_SYNC
  POPULARITY_UPDATE
  STALE_REFRESH
  FULL_GAME_SYNC
  CATEGORY_ROTATION
}

enum SyncJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model SyncSource {
  id               String         @id @default(cuid())
  type             SyncSourceType
  name             String
  baseUrl          String?
  gameId           String?
  externalGameId   String?
  enabled          Boolean        @default(true)
  config           Json?
  lastFullSyncAt   DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  game        Game?           @relation(fields: [gameId], references: [id], onDelete: SetNull)
  indexedMods IndexedMod[]
  syncLogs    SyncLog[]
  queueItems  SyncQueueItem[]

  @@unique([type, externalGameId])
  @@index([enabled])
}

model IndexedAuthor {
  id          String         @id @default(cuid())
  externalId  String?
  source      SyncSourceType
  name        String
  slug        String?
  profileUrl  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  mods IndexedMod[]

  @@unique([source, externalId])
  @@index([name])
}

model IndexedMod {
  id                 String         @id @default(cuid())
  externalId         String
  source             SyncSourceType
  syncSourceId       String?
  name               String
  slug               String         @unique
  description        String?        @db.Text
  shortDescription   String?
  version            String?
  authorId           String?
  authorName         String?
  gameId             String?
  categoryExternalId    String?
  categoryName          String?
  rootCategoryName      String?
  rootCategoryExternalId String?
  rootCategoryIconUrl   String?
  subCategoryName       String?
  subCategoryExternalId String?
  subCategoryIconUrl    String?
  isNsfw             Boolean        @default(false)
  views              Int            @default(0)
  downloads          Int            @default(0)
  likes              Int            @default(0)
  downloadsRecent    Int            @default(0)
  viewsRecent        Int            @default(0)
  thumbnailUrl       String?
  thumbnailCachedKey String?
  externalUrl        String?
  downloadUrl        String?
  mirrorUrls         String[]       @default([])
  fileSizeBytes      BigInt?
  checksum           String?
  etag               String?
  contentHash        String?
  syncPriority       Int            @default(50)
  priorityScore      Float          @default(0)
  failedSyncAttempts Int            @default(0)
  externalUpdatedAt  DateTime?
  lastSyncAt         DateTime?
  lastSuccessfulSync DateTime?
  nextSyncAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  syncSource SyncSource?         @relation(fields: [syncSourceId], references: [id], onDelete: SetNull)
  author     IndexedAuthor?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  game       Game?               @relation(fields: [gameId], references: [id], onDelete: SetNull)
  images     IndexedModImage[]
  versions   IndexedModVersion[]
  tags       IndexedModTag[]

  @@unique([source, externalId])
  @@index([gameId])
  @@index([syncPriority])
  @@index([priorityScore])
  @@index([nextSyncAt])
  @@index([lastSuccessfulSync])
  @@index([downloads])
  @@index([updatedAt])
}

model IndexedModImage {
  id        String  @id @default(cuid())
  modId     String
  url       String
  cachedKey String?
  sortOrder Int     @default(0)

  mod IndexedMod @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@index([modId])
}

model IndexedModVersion {
  id                String    @id @default(cuid())
  modId             String
  version           String
  downloadUrl       String?
  fileSizeBytes     BigInt?
  checksum          String?
  changelog         String?   @db.Text
  externalUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  mod IndexedMod @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@unique([modId, version])
}

model IndexedModTag {
  modId String
  tag   String

  mod IndexedMod @relation(fields: [modId], references: [id], onDelete: Cascade)

  @@id([modId, tag])
  @@index([tag])
}

model SyncLog {
  id           String         @id @default(cuid())
  syncSourceId String?
  jobType      SyncJobType
  status       SyncJobStatus
  message      String?
  metadata     Json?
  durationMs   Int?
  rateLimitHit Boolean        @default(false)
  createdAt    DateTime       @default(now())

  syncSource SyncSource? @relation(fields: [syncSourceId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([jobType, status])
}

model SyncQueueItem {
  id           String         @id @default(cuid())
  bullJobId    String?        @unique
  jobType      SyncJobType
  status       SyncJobStatus  @default(PENDING)
  priority     Int            @default(0)
  payload      Json
  attempts     Int            @default(0)
  maxAttempts  Int            @default(5)
  lastError    String?
  scheduledFor DateTime       @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  syncSourceId String?
  indexedModId String?

  syncSource SyncSource? @relation(fields: [syncSourceId], references: [id], onDelete: SetNull)

  @@index([status, scheduledFor])
  @@index([jobType, status])
}
