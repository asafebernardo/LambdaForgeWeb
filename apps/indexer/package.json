    "postinstall": "prisma generate --schema=../api/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.49.0",
    "dotenv": "^16.5.0",
    "meilisearch": "^0.49.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
