# Database
DATABASE_URL=postgresql://lambdaforge:lambdaforge@localhost:5432/lambdaforge

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lambdaforge-mods
S3_PUBLIC_URL=http://localhost:9000/lambdaforge-mods

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=dev-master-key

# API
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
