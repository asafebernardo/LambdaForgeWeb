{
  "name": "lambda-forge",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "docker compose up -d && turbo dev",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:reset": "pnpm --filter api db:reset",
    "db:test": "pnpm --filter api db:test"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  }
}
